ODOO_URL=https://your-odoo.example.com
ODOO_DB=your_database
ODOO_USERNAME=your_username
ODOO_PASSWORD=your_password_or_api_key
ODOO_TIMEOUT=120
ODOO_RETRY_ATTEMPTS=3
ODOO_RETRY_BACKOFF_SECONDS=0.5
ODOO_RETRY_BACKOFF_MAX_SECONDS=4
ODOO_MAX_REDIRECTS=5
ODOO_VERIFY_SSL=true

MCP_HOST=0.0.0.0
MCP_PORT=6969
MCP_LOG_LEVEL=info
MCP_TOOLSETS=hrm
MCP_RATE_LIMIT_ENABLED=true
MCP_RATE_LIMIT_MAX_CALLS=60
MCP_RATE_LIMIT_WINDOW_SECONDS=60
MCP_AUDIT_LOG_PATH=logs/odoo_audit.jsonl

# Set both files to enable native HTTPS on the MCP listener itself.
# MCP_SSL_CERTFILE=/absolute/path/to/server.crt
# MCP_SSL_KEYFILE=/absolute/path/to/server.key
# MCP_SSL_KEYFILE_PASSWORD=
